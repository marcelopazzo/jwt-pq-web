<% content_for :title, "JWT debugger" %>
<% content_for :description, "Verify post-quantum JWTs — ML-DSA and hybrid EdDSA+ML-DSA — against the live jwt-pq gem." %>

<section class="page">
  <header class="docs-hero">
    <span class="ruleset">standalone permalink</span>
    <h1 class="docs-hero__title">
      <span class="text-display-italic">JWT</span> debugger.
    </h1>
    <p class="docs-hero__lede">
      Every verification below runs <code class="code-inline">JWT::PQ::JWK.import</code>
      and <code class="code-inline">JWT.decode</code> server-side against the
      real jwt-pq gem. No JavaScript reimplementation, no cached result.
      Share this page — token + JWK are posted over HTTPS and never stored.
    </p>
  </header>

  <%= render "shared/debugger" %>
</section>
