<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "jwt-pq" %> — Post-quantum JWT for Ruby</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#08090b">
    <meta name="color-scheme" content="dark">
    <meta name="description" content="<%= content_for?(:description) ? yield(:description) : "Post-quantum JWT signatures for Ruby. ML-DSA (FIPS 204) and hybrid EdDSA+ML-DSA, verified server-side against the real gem." %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">

    <meta property="og:title" content="jwt-pq — Post-quantum JWT for Ruby">
    <meta property="og:description" content="Post-quantum JWT signatures for Ruby. ML-DSA (FIPS 204) and hybrid EdDSA+ML-DSA.">
    <meta property="og:type" content="website">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="relative min-h-full bg-canvas text-fg-primary antialiased font-mono selection:bg-accent/25 selection:text-fg-primary">
    <div class="lattice pointer-events-none fixed inset-0 z-0" aria-hidden="true"></div>
    <div class="bloom pointer-events-none fixed inset-x-0 top-[-20rem] h-[40rem] z-0" aria-hidden="true"></div>

    <div class="relative z-10 flex min-h-screen flex-col">
      <%= render "shared/header" %>
      <main class="flex-1">
        <%= yield %>
      </main>
      <%= render "shared/footer" %>
    </div>
  </body>
</html>
