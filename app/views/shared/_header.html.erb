<% current = request.path %>
<header class="site-header">
  <div class="site-header__inner">
    <%= link_to root_path, class: "brand" do %>
      <span class="brand__glyph" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.4">
          <path d="M6 6h20v20H6z" opacity="0.25" />
          <path d="M10 10h12v12H10z" />
          <path d="M14 14h4v4h-4z" fill="currentColor" stroke="none" />
        </svg>
      </span>
      <span class="brand__word">jwt<span class="brand__word-accent">-pq</span></span>
      <span class="brand__tag">ruby</span>
    <% end %>

    <nav class="site-nav" aria-label="Primary">
      <%= link_to "Quickstart", quickstart_path, class: "nav-link#{' is-active' if current == quickstart_path}" %>
      <%= link_to "Algorithms", algorithms_path, class: "nav-link#{' is-active' if current == algorithms_path}" %>
      <%= link_to "Hybrid", hybrid_path, class: "nav-link#{' is-active' if current == hybrid_path}" %>
      <%= link_to "Security", security_path, class: "nav-link#{' is-active' if current == security_path}" %>
      <%= link_to "Debugger", debugger_path, class: "nav-link#{' is-active' if current == debugger_path}" %>
      <span class="site-nav__rule" aria-hidden="true"></span>
      <a href="https://docs.jwt-pq.marcelopazzo.com" class="nav-link nav-link--ext" rel="noopener" target="_blank">
        API <span aria-hidden="true">↗</span>
      </a>
      <a href="https://github.com/marcelopazzo/jwt-pq" class="nav-link nav-link--ext" rel="noopener" target="_blank">
        GitHub <span aria-hidden="true">↗</span>
      </a>
    </nav>
  </div>
</header>
